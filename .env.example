# CraftDock environment variables
# Copy this file to .env for local development overrides

# Microsoft OAuth client ID
# Optional — defaults to the public Minecraft client ID used by Prism/MultiMC
# MS_CLIENT_ID=00000000402b5328

# CurseForge API key
# Optional — a key is baked into the app so users don't need their own.
# Override here only if you want to use your own key during development.
# CF_API_KEY=your_key_here
